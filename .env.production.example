# 天翼云生产部署环境变量模板
# 复制：cp .env.production.example .env.production && vim .env.production
# 启动：docker compose -f docker-compose.prod.yml --env-file .env.production up -d

# ── 域名 ──────────────────────────────────────
PUBLIC_URL=https://manpower.your-domain.com

# ── 数据库（任选其一）─────────────────────────
# A. 自托管 Postgres（docker-compose.prod.yml 自带容器）
POSTGRES_USER=manpower
POSTGRES_PASSWORD=please-generate-with-openssl-rand-hex-32
POSTGRES_DB=manpower

# B. 天翼云 RDS PostgreSQL（推荐生产环境）
#    创建 RDS 实例后，在 docker-compose.prod.yml 里：
#      1. 删掉 services.postgres 整段
#      2. 把 backend.depends_on 里的 postgres 删掉
#      3. backend.environment.DATABASE_URL 改成下面这种
# DATABASE_URL=postgresql+asyncpg://用户:密码@rds-xxxx.ctyun.cn:5432/manpower

# ── 加密 / 鉴权 ──────────────────────────────
# JWT 签名密钥 — 一定要换！
# 生成：openssl rand -hex 32
JWT_SECRET=CHANGE-ME-OPENSSL-RAND-HEX-32-CHARS-MINIMUM

# 字段加密 (HKID 等敏感字段 AES-GCM 用)
# 生成：openssl rand -base64 32
# ⚠️ 这个密钥一旦改了，已加密的字段就解不出来 — 备份好
FIELD_ENCRYPTION_KEY=CHANGE-ME-BASE64-32BYTE-KEY

# ── 驾驶舱访问控制 ──────────────────────────
# 哪些 IP 不带 token 也能访问驾驶舱（会议室大屏 IP）
COCKPIT_ALLOWED_IPS=10.0.0.5,10.0.0.6
# 临时分享给领导手机用的 token（H5 加 ?token=xxx 即可）
COCKPIT_TOKEN=please-rotate-monthly

# ── 默认管理员（首次启动 seed 用，之后改密码）──
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=please-change-on-first-login

# ── 飞书集成（Phase 4 真接时填写；现在留空走 log channel）──
NOTIFICATION_CHANNELS=log
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BOT_WEBHOOK_URL=
FEISHU_EVENT_VERIFY_TOKEN=
FEISHU_EVENT_ENCRYPT_KEY=

# ── 天翼云对象存储 OOS（可选，Phase 4 把上传换到云存储）──
# CTYUN_OOS_ENDPOINT=
# CTYUN_OOS_AK=
# CTYUN_OOS_SK=
# CTYUN_OOS_BUCKET=manpower-uploads
