# Root-level env reference (mirrors backend/.env.example).
# In dev, each service reads its own .env; this file is for docker-compose convenience.

POSTGRES_USER=manpower
POSTGRES_PASSWORD=manpower
POSTGRES_DB=manpower

DATABASE_URL=postgresql+asyncpg://manpower:manpower@localhost:5432/manpower
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=please-change-me-to-a-long-random-string
COCKPIT_TOKEN=cockpit-dev-token
COCKPIT_ALLOWED_IPS=127.0.0.1,::1

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
